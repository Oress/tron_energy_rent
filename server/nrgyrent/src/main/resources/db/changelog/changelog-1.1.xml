<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="create table nrg_auto_aml_sessions" author="oress">
        <createSequence sequenceName="nrg_auto_aml_sessions_seq"
                        dataType="bigint"
                        incrementBy="1"
                        startValue="1"/>

        <createTable tableName="nrg_auto_aml_sessions">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false" unique="true"/>
            </column>
            <column name="address" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="threshold_sun" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="message_to_update" type="bigint"/>
            <column name="chat_id" type="bigint"/>
            <column name="is_active" type="boolean">
                <constraints nullable="false"/>
            </column>
            <column name="deactivated_at" type="TIMESTAMP"/>
            <column name="deactivation_reason" type="text"/>
            <column name="created_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="create index idx_nrg_auto_aml_sessions_address" author="oress">
        <createIndex indexName="idx_nrg_auto_aml_sessions_address" tableName="nrg_auto_aml_sessions">
            <column name="address"/>
        </createIndex>
    </changeSet>

    <changeSet id="create index idx_nrg_auto_aml_sessions_is_active" author="oress">
        <createIndex indexName="idx_nrg_auto_aml_sessions_is_active" tableName="nrg_auto_aml_sessions">
            <column name="is_active"/>
        </createIndex>
    </changeSet>

    <changeSet id="create index idx_nrg_auto_aml_sessions_user_id" author="oress">
        <createIndex indexName="idx_nrg_auto_aml_sessions_user_id" tableName="nrg_auto_aml_sessions">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="create fk fk_nrg_auto_aml_sessions_user_id" author="oress">
        <addForeignKeyConstraint constraintName="fk_nrg_auto_aml_sessions_user_id"
                                 baseTableName="nrg_auto_aml_sessions"
                                 baseColumnNames="user_id"
                                 referencedTableName="nrg_users"
                                 referencedColumnNames="telegram_id"/>
    </changeSet>

</databaseChangeLog>
